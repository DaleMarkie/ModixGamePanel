{
  "name": "modix-panel",
  "version": "1.1.2",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "installmodix": "node scripts/installmodix.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "next dev -p 3000",
    "dev:backend": "venv/bin/python -m backend.api_main",
    "build": "next build",
    "start": "npm run dev"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@uiw/react-codemirror": "^4.25.2",
    "axios": "^1.12.2",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.544.0",
    "next": "14.2.33",
    "react": "18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-color": "^2.19.3",
    "react-dom": "18.2.0",
    "react-icons": "^4.10.1"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "@types/react": "19.1.15",
    "autoprefixer": "^10.4.15",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.4",
    "typescript": "5.9.2"
  }
}
